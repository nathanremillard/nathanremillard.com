---
const { title = "Nathan J. Remillard", description = "Policy researcher and scholar focused on drug policy, education policy, environmental policy, and health care policy." } = Astro.props;
---
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={`https://nathanremillard.com${Astro.url.pathname}`} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Nathan J. Remillard" />
		<meta property="og:image" content="https://nathanremillard.com/og-image.png" />
		<meta name="twitter:image" content="https://nathanremillard.com/og-image.png" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			body { font-family: system-ui, -apple-system, sans-serif; background: #F7F7F5; color: #1C2128; }
			nav { display: flex; align-items: center; justify-content: space-between; padding: 20px 48px; border-bottom: 1px solid #DDE0D8; }
			.nav-name { font-size: 15px; font-weight: 600; letter-spacing: 0.02em; text-decoration: none; color: #1C2128; }
			.nav-links { display: flex; gap: 28px; list-style: none; }
			.nav-links a { font-size: 13px; color: #5A6170; text-decoration: none; letter-spacing: 0.01em; }
			.nav-links a:hover { color: #2D5016; }
			footer { padding: 28px 48px; border-top: 1px solid #DDE0D8; display: flex; justify-content: space-between; align-items: center; }
			.footer-copy { font-size: 12px; color: #8A9099; }
			.footer-links { display: flex; gap: 20px; }
			.footer-links a { font-size: 12px; color: #5A6170; text-decoration: none; }
			.footer-links a:hover { color: #2D5016; }
			@media (max-width: 768px) {
				nav {
					flex-direction: column;
					align-items: flex-start;
					gap: 16px;
					padding: 20px 24px;
				}
				.nav-links {
					gap: 16px;
					flex-wrap: wrap;
				}
				footer {
					flex-direction: column;
					align-items: flex-start;
					gap: 16px;
					padding: 28px 24px;
				}
			}
		</style>
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-WD16YHX9WC"></script>
		<script>
			(window as any).dataLayer = (window as any).dataLayer || [];
			function gtag(...args: any[]){(window as any).dataLayer.push(args);}
			gtag('js', new Date());

			gtag('config', 'G-WD16YXH9WC');
		</script>
	</head>
	<body>
		<nav>
			<a class="nav-name" href="/">Nathan J. Remillard</a>
			<ul class="nav-links">
				<li><a href="/">Home</a></li>
				<li><a href="/about">About</a></li>
				<li><a href="/research">Research</a></li>
				<li><a href="/publications">Publications</a></li>
				<li><a href="/writing">Writing</a></li>
				<li><a href="/projects">Projects</a></li>
				<li><a href="/contact">Contact</a></li>
			</ul>
		</nav>
		<slot />
		<footer>
			<span class="footer-copy">© 2026 Nathan J. Remillard</span>
			<div class="footer-links">
				<a href="/cv.pdf">CV</a>
				<a href="https://scholar.google.com/citations?user=fNv21qEAAAAJ&hl=en" target="_blank" class="contact-link">Google Scholar</a>
				<a href="https://linkedin.com/in/nathanremillard" target="_blank" class="contact-link">LinkedIn</a>
				<a href="mailto:nathanremillard5@gmail.com">Email</a>
			</div>
		</footer>
	</body>
</html>