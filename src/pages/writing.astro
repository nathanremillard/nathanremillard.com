---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Layout title="Writing — Nathan J. Remillard">
  <main>
    <section class="writing-hero">
      <p class="label">Writing</p>
      <h1>Essays & commentary</h1>
      <p class="subhead">Accessible writing on policy, research, and the systems that shape everyday life. Longer than a tweet, shorter than a dissertation.</p>
    </section>

    <div class="divider"></div>

    <section class="section">
      {posts.length === 0 ? (
        <div class="empty">
          <p>No posts yet — check back soon.</p>
        </div>
      ) : (
        <div class="post-list">
          {posts.map((post) => (
            <a href={`/writing/${post.id}`} class="post-item">
              <div class="post-left">
                <p class="post-title">{post.data.title}</p>
                <p class="post-desc">{post.data.description}</p>
              </div>
              <div class="post-right">
                <span class="post-tag">{post.data.tag}</span>
                <span class="post-date">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  </main>
</Layout>

<style>
  main { max-width: 1000px; margin: 0 auto; }
  .writing-hero { padding: 72px 48px 56px; max-width: 680px; }
  .label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #4A6741; font-weight: 600; margin-bottom: 16px; }
  h1 { font-size: 40px; font-weight: 700; letter-spacing: -0.02em; color: #1C2128; margin-bottom: 20px; }
  .subhead { font-size: 18px; line-height: 1.75; color: #3D4654; }
  .divider { height: 1px; background: #DDE0D8; margin: 0 48px; }
  .section { padding: 52px 48px; }
  .empty { font-size: 15px; color: #8A9099; }
  .post-list { display: flex; flex-direction: column; }
  .post-item { display: flex; justify-content: space-between; align-items: baseline; padding: 20px 0; border-bottom: 1px solid #DDE0D8; gap: 24px; text-decoration: none; }
  .post-item:last-child { border-bottom: none; }
  .post-item:hover .post-title { color: #2D5016; }
  .post-left { flex: 1; }
  .post-title { font-size: 16px; font-weight: 600; color: #1C2128; margin-bottom: 6px; transition: color 0.15s; }
  .post-desc { font-size: 13px; color: #5A6170; line-height: 1.6; }
  .post-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; white-space: nowrap; }
  .post-tag { font-size: 11px; background: #E8EDE4; color: #2D5016; padding: 3px 10px; border-radius: 2px; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; }
  .post-date { font-size: 12px; color: #8A9099; }

  @media (max-width: 768px) {
    .writing-hero { padding: 48px 24px 40px; }
    h1 { font-size: 32px; }
    .subhead { font-size: 16px; }
    .divider { margin: 0 24px; }
    .section { padding: 40px 24px; }
    .post-item { flex-direction: column; gap: 12px; }
    .post-right { align-items: flex-start; flex-direction: row; }
  }
</style>